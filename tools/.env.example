# ── Required ──────────────────────────────────────────────────
# Get from: https://console.apify.com → Settings → Integrations
APIFY_TOKEN=your_apify_api_token_here

# ── LLM: Pick ONE ─────────────────────────────────────────────

# Option A (FREE): Ollama running locally
# Install: https://ollama.com/download
# Then run: ollama pull llama3.1
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Option B (Paid, higher quality): Claude API
# Get from: https://console.anthropic.com → API Keys
# If set, Claude is used instead of Ollama automatically
# ANTHROPIC_API_KEY=your_claude_api_key_here
